# Backend API
PORT=3001

# URL base del servicio Laravel Auth (tu proyecto Auth)
AUTH_BASE_URL=http://localhost

# OAuth2 password grant (Laravel Passport)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_SCOPE=

# Endpoint para validar el token y obtener usuario autenticado.
# Si tu servicio expone otra ruta, ajustala aqui.
AUTH_USERINFO_URL=http://localhost/api/user

# Cache en ms para evitar validar token en cada request al auth service.
AUTH_USERINFO_CACHE_TTL_MS=30000
